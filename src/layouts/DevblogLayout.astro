---
import Layout from './Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
	title: string;
	activeSlug?: string;
}

const { title, activeSlug } = Astro.props;
const allPosts = await getCollection('devblog');
const sortedPosts = allPosts.sort((a: CollectionEntry<'devblog'>, b: CollectionEntry<'devblog'>) => 
	a.id.localeCompare(b.id)
);
---

<Layout title={`${title} | Synapse Devblog`}>
	<div class="flex min-h-screen">
		<aside class="w-64 border-r border-gray-800 bg-gray-900/50 backdrop-blur-md hidden md:block sticky top-0 h-screen overflow-y-auto p-6">
			<div class="mb-8">
				<a href="/" class="text-blue-400 font-bold hover:underline">Back to Home</a>
				<h2 class="text-xl font-extrabold mt-4 text-white">Devblog</h2>
				<p class="text-xs text-gray-500 uppercase tracking-widest mt-1">Synapse Engine</p>
			</div>
			
			<nav class="space-y-2">
				{sortedPosts.map((post: CollectionEntry<'devblog'>) => (
					<a 
						href={`/devblog/${post.id}`}
						class={`block py-2 px-3 rounded-lg text-sm transition-colors ${
							activeSlug === post.id 
							? 'bg-blue-600/20 text-blue-400 font-medium border border-blue-500/30' 
							: 'text-gray-400 hover:bg-gray-800 hover:text-gray-200'
						}`}
					>
						{post.data.title}
					</a>
				))}
			</nav>
		</aside>

		<main class="flex-1 px-6 py-12 md:px-16 lg:px-24 max-w-5xl mx-auto">
			<article class="prose prose-invert prose-blue max-w-none 
				prose-headings:font-bold prose-h1:text-4xl prose-h1:mb-8 
				prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:border-b prose-h2:border-gray-800 prose-h2:pb-2
				prose-p:text-gray-300 prose-p:leading-relaxed
				prose-code:text-blue-300 prose-pre:bg-gray-900 prose-pre:border prose-pre:border-gray-800">
				
				<slot />
			</article>

			<footer class="mt-16 pt-8 border-t border-gray-800 text-gray-500 text-sm">
				© 2026 Tamás Péter - Synapse Engine Development Blog
			</footer>
		</main>
	</div>
</Layout>