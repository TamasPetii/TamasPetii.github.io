---
interface Props {
	title: string;
	description: string;
	tags: string[];
	link: string;
}
const { title, description, tags, link } = Astro.props;
---

<a href={link} class="group block p-6 bg-gray-900 border border-gray-800 rounded-2xl hover:border-blue-500 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(59,130,246,0.2)]">
	<h3 class="text-2xl font-bold mb-2 group-hover:text-blue-400 transition-colors">{title}</h3>
	<p class="text-gray-400 mb-4">{description}</p>
	<div class="flex flex-wrap gap-2">
		{tags.map((tag) => (
			<span class="px-3 py-1 bg-gray-800 text-sm rounded-full text-gray-300">{tag}</span>
		))}
	</div>
</a>